/* =====================================================
   策略页样式 - 专业设置界面设计
   基于 UI UX Pro Max 设计原则优化
   ===================================================== */

/* -----------------------------------------------------
   页面容器
   ----------------------------------------------------- */
.container {
  padding: var(--space-3);
  padding-bottom: calc(var(--space-6) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-6) + env(safe-area-inset-bottom));
  background-color: var(--bg-primary);
  min-height: 100vh;
}

/* -----------------------------------------------------
   页面标题
   ----------------------------------------------------- */
.page-header {
  margin-bottom: var(--space-4);
  text-align: center;
  padding-top: var(--space-2);
}

.page-title {
  font-size: var(--text-2xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: block;
  margin-bottom: var(--space-2);
  letter-spacing: -0.02em;
}

.page-subtitle {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  line-height: var(--leading-relaxed);
  max-width: 500rpx;
  margin: 0 auto;
}

/* -----------------------------------------------------
   保存状态提示 - Toast 通知
   ----------------------------------------------------- */
.save-status {
  position: fixed;
  top: var(--space-3);
  left: 50%;
  transform: translateX(-50%) translateY(-150rpx);
  padding: var(--space-2) var(--space-5);
  background: linear-gradient(135deg, var(--success-500) 0%, #059669 100%);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-lg);
  z-index: 1000;
  opacity: 0;
  transition: all var(--duration-normal) var(--easing-ease-out);
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.save-status.show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

.save-status::before {
  content: '✓';
  width: 32rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: var(--font-bold);
}

.save-text {
  font-size: var(--text-sm);
  color: var(--text-inverse);
  font-weight: var(--font-semibold);
}

/* -----------------------------------------------------
   策略区块 - 卡片设计
   ----------------------------------------------------- */
.strategy-section {
  margin-bottom: var(--space-4);
  padding: var(--space-4);
  background-color: var(--bg-white);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
  transition: box-shadow var(--duration-normal);
}

.strategy-section:hover {
  box-shadow: var(--shadow-md);
}

.section-header {
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--border-light);
}

.section-title {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-1);
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary-500) 0%, var(--primary-600) 100%);
  border-radius: var(--radius-full);
}

.section-desc {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  font-weight: var(--font-medium);
}

/* -----------------------------------------------------
   预设模板 - 网格卡片
   ----------------------------------------------------- */
.template-section {
  margin-bottom: var(--space-4);
}

.template-title {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.template-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2);
}

.template-btn {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  border: 2rpx solid transparent;
  transition: all var(--duration-fast) var(--easing-ease-out);
}

.template-btn:active {
  transform: scale(0.98);
}

.template-btn.active {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--bg-white) 100%);
  box-shadow: var(--shadow-sm);
}

.template-icon {
  font-size: var(--text-2xl);
  margin-right: var(--space-2);
  flex-shrink: 0;
}

.template-info {
  flex: 1;
  min-width: 0;
}

.template-name {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.template-btn.active .template-name {
  color: var(--primary-700);
}

.template-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* -----------------------------------------------------
   条件列表 - 选中卡片式
   ----------------------------------------------------- */
.conditions-section {
  margin-top: var(--space-3);
}

.conditions-title {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.conditions-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.condition-item {
  display: flex;
  align-items: flex-start;
  padding: var(--space-3);
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  border: 2rpx solid transparent;
  transition: all var(--duration-fast) var(--easing-ease-out);
}

.condition-item:active {
  background-color: var(--bg-tertiary);
  transform: scale(0.99);
}

.condition-item.active {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--bg-white) 100%);
  box-shadow: var(--shadow-sm);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--border-medium);
  border-radius: var(--radius-md);
  margin-right: var(--space-3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
  background-color: var(--bg-white);
  transition: all var(--duration-fast);
}

.checkbox.checked {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: var(--shadow-xs);
}

.checkbox.checked::after {
  content: '';
  width: 20rpx;
  height: 12rpx;
  border-left: 3rpx solid white;
  border-bottom: 3rpx solid white;
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

.condition-content {
  flex: 1;
  min-width: 0;
}

.condition-name {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.condition-item.active .condition-name {
  color: var(--primary-700);
}

.condition-desc {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  line-height: var(--leading-normal);
}

/* -----------------------------------------------------
   止损模式选择
   ----------------------------------------------------- */
.mode-selector {
  margin-bottom: var(--space-4);
}

.mode-title {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
  display: block;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.mode-tabs {
  display: flex;
  gap: var(--space-2);
}

.mode-tab {
  flex: 1;
  padding: var(--space-3) var(--space-2);
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  text-align: center;
  border: 2rpx solid transparent;
  transition: all var(--duration-fast) var(--easing-ease-out);
}

.mode-tab:active {
  background-color: var(--bg-tertiary);
  transform: scale(0.98);
}

.mode-tab.active {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--bg-white) 100%);
  box-shadow: var(--shadow-sm);
}

.mode-icon {
  font-size: var(--text-2xl);
  display: block;
  margin-bottom: var(--space-2);
}

.mode-name {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.mode-tab.active .mode-name {
  color: var(--primary-700);
}

.mode-desc {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  line-height: 1.3;
}

/* -----------------------------------------------------
   固定比例输入
   ----------------------------------------------------- */
.fixed-loss-setting {
  margin-top: var(--space-3);
  padding: var(--space-3);
  background-color: var(--bg-secondary);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
}

.input-group {
  display: flex;
  flex-direction: column;
}

.input-label {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
  display: block;
}

.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-3);
  border: 2rpx solid var(--border-medium);
  border-radius: var(--radius-md);
  font-size: var(--text-lg);
  box-sizing: border-box;
  background-color: var(--bg-white);
  margin-bottom: var(--space-2);
  color: var(--text-primary);
  font-weight: var(--font-medium);
  font-family: var(--font-mono);
  transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
}

.input-field:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3rpx var(--primary-100);
  outline: none;
}

.input-hint {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  line-height: var(--leading-normal);
}

/* -----------------------------------------------------
   提示信息 - 信息卡片
   ----------------------------------------------------- */
.tips-section {
  margin-top: var(--space-4);
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  padding: var(--space-3);
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--info-50) 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--primary-100);
  border-left: 4rpx solid var(--color-primary);
}

.tip-icon {
  font-size: var(--text-xl);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-text {
  flex: 1;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
}

/* -----------------------------------------------------
   无障碍增强
   ----------------------------------------------------- */
@media (prefers-reduced-motion: reduce) {
  .template-btn,
  .condition-item,
  .mode-tab,
  .save-status {
    transition: none;
  }
  
  .template-btn:active,
  .condition-item:active,
  .mode-tab:active {
    transform: none;
  }
}
