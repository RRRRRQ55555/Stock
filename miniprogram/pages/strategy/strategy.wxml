<!-- 策略页 - 纯设置页面：只负责设置买入/止损条件，自动保存 -->
<view class="container">

  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">我的投资策略</text>
    <text class="page-subtitle">设置你的交易规则，首页搜索股票时将自动匹配</text>
  </view>

  <!-- 保存状态提示 -->
  <view class="save-status {{saveStatus ? 'show' : ''}}">
    <text class="save-text">{{saveStatus}}</text>
  </view>

  <!-- ========== 买入策略设置 ========== -->
  <view class="strategy-section card">
    <view class="section-header">
      <text class="section-title">📈 买入策略</text>
      <text class="section-desc">设定买入时的技术指标条件</text>
    </view>

    <!-- 预设模板 -->
    <view class="template-section">
      <text class="template-title">快速预设模板</text>
      <view class="template-list">
        <view class="template-btn {{buyTemplate === 'conservative' ? 'active' : ''}}" bindtap="applyBuyTemplate" data-template="conservative">
          <text class="template-icon">🛡️</text>
          <view class="template-info">
            <text class="template-name">保守型</text>
            <text class="template-desc">MACD金叉 + 均线上穿</text>
          </view>
        </view>
        <view class="template-btn {{buyTemplate === 'aggressive' ? 'active' : ''}}" bindtap="applyBuyTemplate" data-template="aggressive">
          <text class="template-icon">⚡</text>
          <view class="template-info">
            <text class="template-name">激进型</text>
            <text class="template-desc">KDJ超卖 + 站上MA10</text>
          </view>
        </view>
        <view class="template-btn {{buyTemplate === 'momentum' ? 'active' : ''}}" bindtap="applyBuyTemplate" data-template="momentum">
          <text class="template-icon">🚀</text>
          <view class="template-info">
            <text class="template-name">动量型</text>
            <text class="template-desc">站上MA10 + RSI低位</text>
          </view>
        </view>
        <view class="template-btn {{buyTemplate === 'custom' ? 'active' : ''}}" bindtap="applyBuyTemplate" data-template="custom">
          <text class="template-icon">⚙️</text>
          <view class="template-info">
            <text class="template-name">自定义</text>
            <text class="template-desc">手动选择条件组合</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 买入条件列表 -->
    <view class="conditions-section">
      <text class="conditions-title">买入条件（可多选）</text>
      <view class="conditions-list">
        <view class="condition-item {{buyConditions.macdGolden ? 'active' : ''}}" bindtap="toggleBuyCondition" data-key="macdGolden">
          <view class="checkbox {{buyConditions.macdGolden ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">MACD金叉</text>
            <text class="condition-desc">DIF上穿Signal线，趋势转强</text>
          </view>
        </view>

        <view class="condition-item {{buyConditions.maGolden ? 'active' : ''}}" bindtap="toggleBuyCondition" data-key="maGolden">
          <view class="checkbox {{buyConditions.maGolden ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">均线上穿</text>
            <text class="condition-desc">短期均线上穿长期均线</text>
          </view>
        </view>

        <view class="condition-item {{buyConditions.priceAboveMA5 ? 'active' : ''}}" bindtap="toggleBuyCondition" data-key="priceAboveMA5">
          <view class="checkbox {{buyConditions.priceAboveMA5 ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">股价站上MA5</text>
            <text class="condition-desc">价格高于5日均线，显示强势</text>
          </view>
        </view>

        <view class="condition-item {{buyConditions.priceAboveMA10 ? 'active' : ''}}" bindtap="toggleBuyCondition" data-key="priceAboveMA10">
          <view class="checkbox {{buyConditions.priceAboveMA10 ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">股价站上MA10</text>
            <text class="condition-desc">价格高于10日均线，中期强势</text>
          </view>
        </view>

        <view class="condition-item {{buyConditions.kdjOversold ? 'active' : ''}}" bindtap="toggleBuyCondition" data-key="kdjOversold">
          <view class="checkbox {{buyConditions.kdjOversold ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">KDJ超卖反弹</text>
            <text class="condition-desc">J值&lt;0，适合抄底买入</text>
          </view>
        </view>

        <view class="condition-item {{buyConditions.rsiOversold ? 'active' : ''}}" bindtap="toggleBuyCondition" data-key="rsiOversold">
          <view class="checkbox {{buyConditions.rsiOversold ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">RSI超卖</text>
            <text class="condition-desc">RSI&lt;30，进入超卖区域</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 止损策略设置 ========== -->
  <view class="strategy-section card">
    <view class="section-header">
      <text class="section-title">🛡️ 止损策略</text>
      <text class="section-desc">设定触发止损的条件</text>
    </view>

    <!-- 止损模式切换 -->
    <view class="mode-selector">
      <text class="mode-title">止损方式</text>
      <view class="mode-tabs">
        <view class="mode-tab {{stopLossMode === 'technical' ? 'active' : ''}}" bindtap="setStopLossMode" data-mode="technical">
          <text class="mode-icon">📊</text>
          <text class="mode-name">技术指标</text>
          <text class="mode-desc">根据技术信号止损</text>
        </view>
        <view class="mode-tab {{stopLossMode === 'fixed' ? 'active' : ''}}" bindtap="setStopLossMode" data-mode="fixed">
          <text class="mode-icon">📏</text>
          <text class="mode-name">固定比例</text>
          <text class="mode-desc">设定固定亏损比例</text>
        </view>
      </view>
    </view>

    <!-- 固定比例设置 -->
    <view class="fixed-loss-setting" wx:if="{{stopLossMode === 'fixed'}}">
      <view class="input-group">
        <text class="input-label">止损比例 (%)</text>
        <input
          class="input-field"
          type="number"
          value="{{fixedLossPct}}"
          bindinput="onFixedLossInput"
          placeholder="如：-8 表示亏损8%时止损"
        />
        <text class="input-hint">负值表示亏损，如 -8 表示亏损8%时止损卖出</text>
      </view>
    </view>

    <!-- 技术指标条件 -->
    <view class="conditions-section" wx:if="{{stopLossMode === 'technical'}}">
      <text class="conditions-title">止损信号条件（满足任一即触发）</text>
      <view class="conditions-list">
        <view class="condition-item {{stopConditions.macdDeath ? 'active' : ''}}" bindtap="toggleStopCondition" data-key="macdDeath">
          <view class="checkbox {{stopConditions.macdDeath ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">MACD死叉</text>
            <text class="condition-desc">DIF下穿Signal，趋势转弱</text>
          </view>
        </view>

        <view class="condition-item {{stopConditions.maDeath ? 'active' : ''}}" bindtap="toggleStopCondition" data-key="maDeath">
          <view class="checkbox {{stopConditions.maDeath ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">均线死叉</text>
            <text class="condition-desc">短期均线下穿长期均线</text>
          </view>
        </view>

        <view class="condition-item {{stopConditions.priceBelowMA5 ? 'active' : ''}}" bindtap="toggleStopCondition" data-key="priceBelowMA5">
          <view class="checkbox {{stopConditions.priceBelowMA5 ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">跌破MA5</text>
            <text class="condition-desc">跌破5日均线支撑，短线转弱</text>
          </view>
        </view>

        <view class="condition-item {{stopConditions.priceBelowMA20 ? 'active' : ''}}" bindtap="toggleStopCondition" data-key="priceBelowMA20">
          <view class="checkbox {{stopConditions.priceBelowMA20 ? 'checked' : ''}}"></view>
          <view class="condition-content">
            <text class="condition-name">跌破MA10</text>
            <text class="condition-desc">跌破10日均线支撑，中线转弱</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips-section">
    <view class="tip-item">
      <text class="tip-icon">💡</text>
      <text class="tip-text">设置自动保存，返回首页搜索股票即可查看策略匹配结果</text>
    </view>
  </view>

</view>
