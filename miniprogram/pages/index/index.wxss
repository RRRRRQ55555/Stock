/* =====================================================
   首页样式 - 专业金融数据看板设计
   基于 UI UX Pro Max 设计原则优化
   ===================================================== */

/* -----------------------------------------------------
   页面容器
   ----------------------------------------------------- */
.container {
  padding: var(--space-3);
  background-color: var(--bg-primary);
  min-height: 100vh;
  padding-bottom: calc(var(--space-6) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-6) + env(safe-area-inset-bottom));
}

/* -----------------------------------------------------
   搜索栏组件 - Glassmorphism 风格
   ----------------------------------------------------- */
.compact-search-bar {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: var(--radius-lg);
  padding: 0 var(--space-3);
  height: 88rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
  transition: box-shadow var(--duration-normal) var(--easing-ease-out),
              border-color var(--duration-normal) var(--easing-ease-out);
}

.search-box:focus-within {
  box-shadow: var(--shadow-md);
  border-color: var(--primary-300);
}

.search-icon-small {
  font-size: var(--text-lg);
  margin-right: var(--space-2);
  color: var(--text-tertiary);
  transition: color var(--duration-fast);
}

.search-box:focus-within .search-icon-small {
  color: var(--color-primary);
}

.search-input-compact {
  flex: 1;
  height: 88rpx;
  font-size: var(--text-lg);
  background: transparent;
  border: none;
  color: var(--text-primary);
  font-weight: var(--font-medium);
}

.search-input-compact::placeholder {
  color: var(--text-tertiary);
  font-weight: var(--font-normal);
}

.clear-btn-compact {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  color: var(--text-secondary);
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  opacity: 0;
  transform: scale(0.8);
  transition: all var(--duration-fast) var(--easing-ease-out);
}

.clear-btn-compact.show {
  opacity: 1;
  transform: scale(1);
}

.clear-btn-compact:active {
  background: var(--bg-tertiary);
  transform: scale(0.95);
}

.search-btn-compact {
  height: 88rpx;
  padding: 0 var(--space-4);
  background: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-600) 100%);
  color: var(--text-inverse);
  border-radius: var(--radius-lg);
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-fast) var(--easing-ease-out);
  min-width: 120rpx;
}

.search-btn-compact:active {
  transform: translateY(1rpx);
  box-shadow: var(--shadow-xs);
  background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-700) 100%);
}

/* -----------------------------------------------------
   已选股票栏 - 突出的数据卡片
   ----------------------------------------------------- */
.stock-search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, var(--bg-white) 0%, var(--primary-50) 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--primary-100);
  margin-bottom: var(--space-3);
  transition: all var(--duration-normal) var(--easing-ease-out);
}

.stock-search-bar:active {
  transform: translateY(-1rpx);
  box-shadow: var(--shadow-md);
}

.stock-display {
  display: flex;
  align-items: center;
  flex: 1;
}

.bar-icon {
  font-size: var(--text-lg);
  margin-right: var(--space-2);
  color: var(--color-primary);
}

.bar-symbol {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--primary-700);
  font-family: var(--font-mono);
}

.bar-divider {
  font-size: var(--text-base);
  color: var(--border-medium);
  margin: 0 var(--space-2);
}

.bar-name {
  font-size: var(--text-base);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
}

.bar-actions {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* -----------------------------------------------------
   搜索下拉菜单
   ----------------------------------------------------- */
.search-dropdown {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  margin-bottom: var(--space-3);
  overflow: hidden;
  border: 1rpx solid var(--border-light);
  animation: slideDown var(--duration-normal) var(--easing-ease-out);
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.dropdown-section {
  padding: var(--space-3);
}

.dropdown-section + .dropdown-section {
  border-top: 1rpx solid var(--border-light);
}

.dropdown-item {
  display: flex;
  align-items: center;
  padding: var(--space-3) 0;
  border-bottom: 1rpx solid var(--border-light);
  transition: background-color var(--duration-fast);
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background-color: var(--bg-secondary);
  margin: 0 calc(-1 * var(--space-3));
  padding-left: var(--space-3);
  padding-right: var(--space-3);
}

.item-symbol {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--color-primary);
  min-width: 160rpx;
  font-family: var(--font-mono);
}

.item-name {
  font-size: var(--text-base);
  color: var(--text-primary);
  font-weight: var(--font-medium);
}

.section-header-compact {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.section-title-compact {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  font-weight: var(--font-semibold);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.clear-link {
  font-size: var(--text-sm);
  color: var(--color-primary);
  font-weight: var(--font-medium);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
  transition: background-color var(--duration-fast);
}

.clear-link:active {
  background-color: var(--primary-50);
}

.history-chips, .hot-chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.history-chip, .hot-chip {
  padding: var(--space-2) var(--space-3);
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  font-size: var(--text-base);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
  transition: all var(--duration-fast);
}

.history-chip:active {
  background: var(--bg-tertiary);
  transform: scale(0.98);
}

.hot-chip {
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--primary-100) 100%);
  color: var(--primary-700);
}

.hot-chip:active {
  background: linear-gradient(135deg, var(--primary-100) 0%, var(--primary-200) 100%);
}

/* -----------------------------------------------------
   股票信息行 - 数据密度高、层级清晰
   ----------------------------------------------------- */
.stock-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-white);
  border-radius: var(--radius-xl);
  padding: var(--space-4) var(--space-4);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
  margin-bottom: var(--space-3);
  transition: all var(--duration-normal) var(--easing-ease-out);
}

.stock-info-row:hover {
  box-shadow: var(--shadow-md);
}

.info-left {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.info-code-name {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.info-symbol {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--color-primary);
  font-family: var(--font-mono);
  letter-spacing: -0.02em;
}

.info-name {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.info-price-wrap {
  display: flex;
  align-items: baseline;
  gap: var(--space-2);
  margin-top: var(--space-1);
}

.info-price {
  font-size: var(--text-3xl);
  font-weight: var(--font-bold);
  font-family: var(--font-mono);
  letter-spacing: -0.02em;
  line-height: var(--leading-tight);
}

.info-price.up {
  color: var(--stock-up);
}

.info-price.down {
  color: var(--stock-down);
}

.info-change {
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  font-family: var(--font-mono);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
}

.info-change.up {
  background-color: var(--error-50);
  color: var(--stock-up);
}

.info-change.down {
  background-color: var(--success-50);
  color: var(--stock-down);
}

.info-right {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* 提醒按钮 - 醒目的操作按钮 */
.alert-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  background: linear-gradient(135deg, var(--warning-50) 0%, #fff 100%);
  border: 2rpx solid var(--warning-500);
  border-radius: var(--radius-md);
  transition: all var(--duration-fast);
}

.alert-btn:active {
  background: linear-gradient(135deg, var(--warning-100) 0%, var(--warning-50) 100%);
  transform: scale(0.98);
}

.alert-icon {
  font-size: var(--text-xl);
}

.alert-text {
  font-size: var(--text-xs);
  color: #b45309;
  font-weight: var(--font-semibold);
}

/* -----------------------------------------------------
   加载状态 - 骨架屏动画
   ----------------------------------------------------- */
.loading-row {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--space-8);
  gap: var(--space-2);
}

.loading-text {
  font-size: var(--text-base);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
}

/* -----------------------------------------------------
   策略看板 - 专业数据仪表风格
   ----------------------------------------------------- */
.strategy-dashboard {
  background: var(--bg-white);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
  margin-bottom: var(--space-3);
  overflow: hidden;
  transition: box-shadow var(--duration-normal);
}

.strategy-dashboard:hover {
  box-shadow: var(--shadow-md);
}

.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-3) var(--space-4);
  background: linear-gradient(135deg, var(--gray-50) 0%, var(--bg-white) 100%);
  border-bottom: 1rpx solid var(--border-light);
}

.dashboard-title {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.dashboard-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary-500) 0%, var(--primary-600) 100%);
  border-radius: var(--radius-full);
}

.dashboard-subtitle {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  font-weight: var(--font-medium);
}

.strategy-row {
  padding: var(--space-4);
  border-bottom: 1rpx solid var(--border-light);
  transition: background-color var(--duration-fast);
}

.strategy-row:last-child {
  border-bottom: none;
}

.strategy-row:active {
  background-color: var(--bg-secondary);
}

.row-header {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}

.row-icon {
  font-size: var(--text-xl);
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-name {
  font-size: var(--text-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  flex: 1;
}

.row-status {
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-sm);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
}

.status-soon {
  background: linear-gradient(135deg, var(--warning-50) 0%, #fff 100%);
  color: #b45309;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.status-far {
  background: var(--bg-secondary);
  color: var(--text-tertiary);
  border: 1rpx solid var(--border-medium);
}

.status-danger {
  background: linear-gradient(135deg, var(--error-50) 0%, #fff 100%);
  color: #dc2626;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.status-safe {
  background: linear-gradient(135deg, var(--success-50) 0%, #fff 100%);
  color: #059669;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

.row-distance {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
  font-family: var(--font-mono);
}

/* 进度条 - 现代渐变风格 */
.progress-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-2);
}

.progress-bar-bg {
  flex: 1;
  height: 12rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.progress-bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width var(--duration-slow) var(--easing-ease-out);
  box-shadow: 0 0 8rpx rgba(0, 0, 0, 0.1);
}

.fill-soon {
  background: linear-gradient(90deg, #f59e0b 0%, #fbbf24 50%, #f59e0b 100%);
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}

.fill-normal {
  background: linear-gradient(90deg, #10b981 0%, #34d399 50%, #10b981 100%);
  background-size: 200% 100%;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.progress-text {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  min-width: 120rpx;
  text-align: right;
  font-family: var(--font-mono);
  font-weight: var(--font-medium);
}

/* 止损信息 */
.stop-loss-info {
  margin-top: var(--space-2);
  padding: var(--space-2);
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  border-left: 4rpx solid var(--warning-500);
}

.stop-line {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  font-family: var(--font-mono);
}

/* -----------------------------------------------------
   共振预警 - 高对比度信息卡
   ----------------------------------------------------- */
.resonance-alert {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--info-50) 100%);
  border: 2rpx solid var(--primary-200);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  position: relative;
  overflow: hidden;
}

.resonance-alert::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-400) 0%, var(--info-400) 100%);
}

.alert-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, var(--primary-100) 0%, var(--primary-50) 100%);
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.alert-big-icon {
  font-size: var(--text-2xl);
}

.alert-content {
  flex: 1;
  min-width: 0;
}

.alert-title {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--primary-700);
  display: block;
  margin-bottom: var(--space-1);
}

.alert-desc {
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
}

/* -----------------------------------------------------
   空状态 - 友好引导
   ----------------------------------------------------- */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: calc(var(--space-10) * 1.5) var(--space-4);
  text-align: center;
}

.tip-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-3);
  opacity: 0.6;
  filter: grayscale(0.3);
}

.tip-text {
  font-size: var(--text-lg);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
  max-width: 400rpx;
  line-height: var(--leading-relaxed);
}

/* -----------------------------------------------------
   关键价格条件列表
   ----------------------------------------------------- */
.critical-conditions {
  margin-top: var(--space-3);
}

.condition-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) 0;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  border-bottom: 1rpx dashed var(--border-light);
}

.condition-item:last-child {
  border-bottom: none;
}

.condition-bullet {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--text-tertiary);
  flex-shrink: 0;
}

.condition-name {
  font-weight: var(--font-medium);
  color: var(--text-secondary);
}

.condition-target {
  margin-left: auto;
  font-family: var(--font-mono);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.condition-distance {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
  font-weight: var(--font-bold);
}

.condition-distance.up {
  background: var(--error-50);
  color: var(--stock-up);
}

.condition-distance.down {
  background: var(--success-50);
  color: var(--stock-down);
}

/* -----------------------------------------------------
   响应式优化
   ----------------------------------------------------- */
@media (min-width: 768px) {
  .container {
    padding: var(--space-4);
  }
  
  .card {
    margin: var(--space-2);
  }
}

/* -----------------------------------------------------
   无障碍增强
   ----------------------------------------------------- */
@media (prefers-reduced-motion: reduce) {
  .search-dropdown,
  .progress-bar-fill,
  .card,
  .btn,
  .clear-btn-compact,
  .search-btn-compact,
  .template-btn,
  .condition-item,
  .mode-tab {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  
  .fill-soon {
    animation: none;
  }
}
