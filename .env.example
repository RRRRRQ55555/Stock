# 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# 前端配置
FRONTEND_PORT=3000

# Tushare API Token (用于A股数据)
# 获取方式：https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# 数据缓存配置
CACHE_DIR=./cache
CACHE_TTL=3600

# 预警阈值
ALERT_PROXIMITY_THRESHOLD=1.0
ALERT_MIN_INTERVAL=300

# 指标默认参数
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9
MA_SHORT_PERIOD=5
MA_LONG_PERIOD=20
KDJ_PERIOD=9
